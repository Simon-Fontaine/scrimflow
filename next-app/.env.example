# Database Configuration
DATABASE_URL=postgresql://scrimflow:change_me_secure_password@localhost:5432/scrimflow_db

# Application URL (used for password reset links, email unsubscribe links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (SMTP)
# Dev:  Mailpit (no auth needed, catches all mail locally)
# Prod: Resend — host=smtp.resend.com port=465 secure=true user=resend pass=re_xxxx
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@scrimflow.local

# Encryption Keys
# Generate a secure key: openssl rand -base64 16
# IMPORTANT: Keep this secret in production — it encrypts TOTP secrets and recovery codes.
ENCRYPTION_KEY=change_me_to_a_secure_random_key

# Redis (optional — in-memory fallback used when unset)
REDIS_URL=redis://:dev_redis_123@localhost:6379

# S3 / MinIO object storage
# When running seeds locally these mirror MINIO_USER / MINIO_PASSWORD from the
# root .env. In Docker Compose the app service receives them automatically.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=change_me_minio_password
S3_BUCKET_AVATARS=avatars
S3_BUCKET_SCREENSHOTS=screenshots
S3_BUCKET_BANNERS=banners
S3_BUCKET_HEROES=heroes
S3_BUCKET_MAPS=maps
# Public-facing URL for generating object URLs (same as S3_ENDPOINT in dev)
S3_PUBLIC_URL=http://localhost:9000

# WebAuthn (Passkeys / Security Keys)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Logging (optional — defaults to "info")
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
